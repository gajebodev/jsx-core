{
  "name": "@gajebodev/jsx-core",
  "version": "1.3.0",
  "description": "Lightweight direct-to-DOM SPA library featuring single-execution JSX components, fine-grained proxy reactivity, client-side routing, micro-stores, and mutation lifecycles.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gajebodev/jsx-core.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./for": {
      "types": "./dist/for.d.ts",
      "import": "./dist/for.js"
    },
    "./show": {
      "types": "./dist/show.d.ts",
      "import": "./dist/show.js"
    },
    "./jsx-runtime": {
      "types": "./dist/jsx-runtime.d.ts",
      "import": "./dist/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./dist/jsx-dev-runtime.d.ts",
      "import": "./dist/jsx-dev-runtime.js"
    }
  },
  "files": [
    "dist",
    "package.json",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "spa",
    "jsx",
    "direct-to-dom",
    "single-execution",
    "vdom-free",
    "proxy-reactivity",
    "fine-grained-reactivity",
    "mutation-observer",
    "lifecycle-hooks",
    "micro-store",
    "router",
    "lightweight"
  ],
  "author": "Gabriel Jefferson Boltron",
  "license": "MIT",
  "devDependencies": {
    "rimraf": "^6.1.3",
    "typescript": "^5.8.3"
  }
}
